{
	"name": "@yd/ui",
	"private": true,
	"version": "2.1.0",
	"license": "MIT",
	"type": "module",
	"svelte": "./src/lib/index.ts",
	"types": "./src/lib/index.ts",
	"exports": {
		".": {
			"types": "./src/lib/index.ts",
			"svelte": "./src/lib/index.ts"
		},
		"./app.css": {
			"style": "./src/app.css"
		}
	},
	"scripts": {
		"prepare": "svelte-kit sync",
		"build": "vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"shadcn": "pnpm shadcn-svelte",
		"shadcn:update": "pnpm shadcn-svelte add -y -o accordion alert alert-dialog badge breadcrumb button checkbox collapsible data-table dropdown-menu empty field input input-group item label select separator sheet sidebar skeleton sonner spinner table tabs textarea tooltip"
	},
	"dependencies": {
		"@fontsource-variable/inter": "latest",
		"@tanstack/table-core": "^8.21.3",
		"bits-ui": "^2.18.0",
		"mode-watcher": "^1.1.0",
		"svelte-sonner": "^1.1.0"
	},
	"peerDependencies": {
		"svelte": "catalog:peers"
	},
	"devDependencies": {
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.8.0",
		"@sveltejs/adapter-auto": "catalog:",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"clsx": "^2.1.1",
		"shadcn-svelte": "^1.2.7",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "catalog:",
		"tslib": "catalog:",
		"tw-animate-css": "^1.4.0",
		"typescript": "catalog:",
		"vite": "catalog:"
	}
}
