{
	"name": "@yd/api",
	"private": true,
	"version": "1.1.0",
	"license": "MIT",
	"description": "API to search and download YouTube videos in various formats.",
	"repository": {
		"type": "git",
		"url": "https://github.com/jordanshatford/youtube-downloader"
	},
	"exports": {
		".": "./openapi.json"
	},
	"scripts": {
		"dev": "uv run fastapi dev",
		"prod": "uv run fastapi run",
		"format": "uv run pre-commit run --all-files",
		"generate:openapi": "uv run python generate_openapi.py",
		"deps:update": "uv sync --upgrade && uv run pre-commit autoupdate"
	}
}
