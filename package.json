{
	"name": "youtube-downloader",
	"version": "1.0.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"prepare": "husky",
		"generate": "pnpm --recursive --sequential generate",
		"web": "pnpm --filter @yd/web -- ",
		"api": "pnpm --filter @yd/api -- ",
		"client": "pnpm --filter @yd/client -- ",
		"ui": "pnpm --filter @yd/ui -- ",
		"dev:web": "pnpm --stream --filter @yd/api --filter @yd/web dev",
		"build": "pnpm --recursive build",
		"format": "prettier --write . && pnpm --filter @yd/api format",
		"check": "pnpm --recursive check",
		"lint": "prettier --check . && eslint . && pnpm --filter @yd/api lint",
		"lint:fix": "eslint --fix .",
		"deps:update": "pnpm self-update && pnpm up --latest && pnpm --recursive up --latest && pnpm --recursive deps:update",
		"changeset": "changeset",
		"commitlint": "commitlint --edit"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@commitlint/types": "^20.5.0",
		"@eslint/js": "^10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@prettier/plugin-oxc": "^0.1.4",
		"@svitejs/changesets-changelog-github-compact": "^1.2.0",
		"@types/node": "^25.6.0",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte-eslint-parser": "^1.6.0",
		"typescript-eslint": "^8.59.0"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=22",
		"pnpm": ">=10"
	}
}
